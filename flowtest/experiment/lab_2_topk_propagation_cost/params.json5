{
  "rng_seed": 7,
  "n_items": 100,
  // 锚点「LLM 调用」次数（两种策略相同）
  "anchor_budget": 120,
  "top_k": 10,
  // 锚点观测翻转概率
  "pair_flip_prob": 0.1,
  // 派生边噪声（略低更易在「嵌入对齐分数」设定下体现传播收益）
  "propagation_derive_flip": 0.02,
  "embed_dim": 16,
  "score_noise_in_embed": 0.15,
  // 仅当 |score_k - score_winner| 不超过该阈值时才接受派生边（贴合「语义近 ≈ 敏感序近」）
  "propagate_score_band": 0.28,
  "n_seeds": 30,
  "output": {
    "result_json": "result.json",
    "figure_dir": "figures",
  },
}
