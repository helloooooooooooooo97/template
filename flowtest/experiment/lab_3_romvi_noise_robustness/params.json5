{
  "rng_seed": 42,
  "n_items": 60,
  "n_pair_samples": 800,
  // 主报告仍用该比例；若提供 noise_flip_ratios 则扫参并写入 sweep
  "noise_flip_ratio": 0.12,
  "noise_flip_ratios": [0.12, 0.28, 0.45],
  "power_iter": 2000,
  "tol": 1e-10,
  "eps": 1e-6,
  // Rank-centrality 均匀跳转比例，保证链可约/遍历
  "teleport": 0.15,
  "n_seeds": 25,
  "output": {
    "result_json": "result.json",
    "figure_dir": "figures",
  },
}
